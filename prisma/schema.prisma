generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                    String                 @id @default(cuid())
  name                  String
  slug                  String                 @unique
  logo                  String?
  email                 String
  phone                 String?
  address               String?                @db.Text
  billingAddress        String?                @db.Text
  gstNumber             String?
  website               String?
  plan                  PlanType               @default(FREE)
  isActive              Boolean                @default(true)
  isSetupComplete       Boolean                @default(false)
  timezone              String                 @default("Asia/Kolkata")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  academicYears         AcademicYear[]
  admissionApplications AdmissionApplication[]
  admissionInquiries    AdmissionInquiry[]
  branches              Branch[]
  feeCategories         FeeCategory[]
  installmentMasters    InstallmentMaster[]
  notices               Notice[]
  roles                 Role[]
  subjectMasters        SubjectMaster[]
  departmentMasters     DepartmentMaster[]
  designationMasters    DesignationMaster[]
  users                 User[]
  classes               Class[]
  students              Student[]
  staff                 Staff[]
  systemSequences       SystemSequence[]
  invoices              Invoice[]
  feePayments           FeePayment[]

  @@map("organizations")
}

model Branch {
  id                    String                 @id @default(cuid())
  organizationId        String
  name                  String
  code                  String
  address               String?                @db.Text
  billingAddress        String?                @db.Text
  gstNumber             String?
  phone                 String?
  email                 String?
  isMain                Boolean                @default(false)
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  hasEntranceTest       Boolean                @default(true)
  admissionApplications AdmissionApplication[]
  admissionInquiries    AdmissionInquiry[]
  books                 Book[]
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classes               Class[]
  events                Event[]
  hostels               Hostel[]
  notices               Notice[]
  staff                 Staff[]
  staffAttendances      StaffAttendance[]
  studentAttendances    StudentAttendance[]
  students              Student[]
  timetables            Timetable[]
  routes                TransportRoute[]
  users                 User[]
  vehicles              Vehicle[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("branches")
}

model User {
  id             String           @id @default(cuid())
  organizationId String
  branchId       String?
  firebaseUid    String           @unique
  email          String
  name           String
  phone          String?
  avatar         String?
  roleId         String
  isActive            Boolean          @default(true)
  forcePasswordChange Boolean          @default(false)
  tokenVersion        Int              @default(1)
  lastLoginAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  parent              Parent?
  staff               Staff?
  student             Student?
  permissions         UserPermission[]
  branch              Branch?          @relation(fields: [branchId], references: [id])
  organization        Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role                Role             @relation(fields: [roleId], references: [id])

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([branchId])
  @@index([roleId])
  @@map("users")
}

enum RoleType {
  STAFF
  STUDENT
  PARENT
}

model Role {
  id              String           @id @default(cuid())
  organizationId  String?
  name            String
  description     String?
  type            RoleType         @default(STAFF)
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users           User[]

  // Shadow Override Fields
  overridesRoleId String?          @map("overrides_role_id")
  overridesRole   Role?            @relation("RoleOverride", fields: [overridesRoleId], references: [id])
  overriddenBy    Role[]           @relation("RoleOverride")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  module          String
  action          String
  description     String?
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId], map: "role_permissions_permissionId_fkey")
  @@map("role_permissions")
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  granted      Boolean    @default(true)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId], map: "user_permissions_permissionId_fkey")
  @@map("user_permissions")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  userId         String?
  action         String
  module         String
  entityId       String
  details        String?  @db.LongText
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([branchId])
  @@index([userId])
  @@index([module, entityId])
  @@map("audit_logs")
}

model AcademicYear {
  id                      String                   @id @default(cuid())
  organizationId          String
  name                    String
  startDate               DateTime
  endDate                 DateTime
  isCurrent               Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  deletedAt               DateTime?
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admissionApplications   AdmissionApplication[]
  admissionInquiries      AdmissionInquiry[]
  classes                 Class[]
  exams                   Exam[]
  feeInstallmentTemplates FeeInstallmentTemplate[]
  feeStructures           FeeStructure[]
  studentEnrollments      StudentEnrollment[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("academic_years")
}

model Class {
  id                      String                   @id @default(cuid())
  branchId                String
  organizationId          String
  academicYearId          String
  name                    String
  numericGrade            Int
  status                  ClassStatus              @default(DRAFT)
  createdAt               DateTime                 @default(now())
  deletedAt               DateTime?
  admissionApplications   AdmissionApplication[]
  admissionInquiries      AdmissionInquiry[]
  academicYear            AcademicYear             @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  branch                  Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  feeInstallmentTemplates FeeInstallmentTemplate[]
  feeStructures           FeeStructure[]
  sections                Section[]
  subjects                Subject[]

  @@unique([branchId, academicYearId, name])
  @@index([branchId])
  @@index([organizationId])
  @@index([academicYearId], map: "classes_academicYearId_fkey")
  @@index([deletedAt])
  @@map("classes")
}

model Section {
  id                     String                  @id @default(cuid())
  classId                String
  name                   String
  classTeacherId         String?
  sectionSubjectTeachers SectionSubjectTeacher[]
  class                  Class                   @relation(fields: [classId], references: [id], onDelete: Cascade)
  classTeacher           Staff?                  @relation("SectionClassTeacher", fields: [classTeacherId], references: [id])
  studentAttendances     StudentAttendance[]
  studentEnrollments     StudentEnrollment[]
  timetableSlots         TimetableSlot[]
  deletedAt              DateTime?

  @@unique([classId, name])
  @@index([classTeacherId])
  @@index([deletedAt])
  @@map("sections")
}

model Subject {
  id                     String                     @id @default(cuid())
  classId                String
  subjectMasterId        String?
  name                   String
  code                   String
  type                   SubjectType                @default(THEORY)
  examSubjects           ExamSubject[]
  sectionSubjectTeachers SectionSubjectTeacher[]
  class                  Class                      @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectMaster          SubjectMaster?             @relation(fields: [subjectMasterId], references: [id])
  teacherAssignments     TeacherSubjectAssignment[]
  timetableSlots         TimetableSlot[]

  @@unique([classId, code])
  @@index([subjectMasterId])
  @@map("subjects")
}

model Student {
  id                 String              @id @default(cuid())
  userId             String?             @unique
  branchId           String
  organizationId     String
  admissionNo        String
  rollNo             String?
  firstName          String
  lastName           String
  dateOfBirth        DateTime
  gender             Gender
  bloodGroup         String?
  photo              String?
  address            String?             @db.Text
  pincode            String?
  previousSchool     String?
  emergencyContact1  String?
  emergencyContact2  String?
  idType             String?
  idNumber           String?
  idDocument         String?
  guardianName       String?
  fatherName         String?
  fatherPhone        String?
  fatherEmail        String?
  fatherOccupation   String?
  motherName         String?
  motherPhone        String?
  motherEmail        String?
  motherOccupation   String?
  admissionDate      DateTime            @default(now())
  status             StudentStatus       @default(ACTIVE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  category           StudentCategory     @default(GENERAL)
  house              String?
  leavingDate        DateTime?
  leavingReason      String?
  bookIssues         BookIssue[]
  feePayments        FeePayment[]
  hostelAlloc        HostelAllocation?
  invoices           Invoice[]
  leavingCertificate LeavingCertificate?
  marks              Mark[]
  attendances        StudentAttendance[]
  enrollments        StudentEnrollment[]
  parentLinks        StudentParent[]
  transportAlloc     StudentTransport?
  branch             Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  deletedAt          DateTime?

  @@unique([branchId, admissionNo])
  @@index([branchId])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("students")
}

model LeavingCertificate {
  id               String   @id @default(cuid())
  studentId        String   @unique
  certificateNo    String   @unique
  issueDate        DateTime @default(now())
  conduct          String   @default("Good")
  leavingDate      DateTime
  reasonForLeaving String
  remarks          String?
  signatoryName    String?
  signatoryTitle   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("leaving_certificates")
}

model StudentEnrollment {
  id             String       @id @default(cuid())
  studentId      String
  academicYearId String
  sectionId      String
  rollNo         String?
  enrolledAt     DateTime     @default(now())
  termType       TermType     @default(FULL_TERM)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  section        Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId])
  @@unique([academicYearId, sectionId, rollNo])
  @@index([sectionId])
  @@map("student_enrollments")
}

model Parent {
  id           String          @id @default(cuid())
  userId       String          @unique
  occupation   String?
  relationship String?
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  children     StudentParent[]

  @@map("parents")
}

model StudentParent {
  id        String  @id @default(cuid())
  studentId String
  parentId  String
  relation  String
  isPrimary Boolean @default(false)
  parent    Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([parentId], map: "student_parents_parentId_fkey")
  @@map("student_parents")
}

model Staff {
  id                      String                     @id @default(cuid())
  userId                  String?                    @unique
  branchId                String
  organizationId          String
  employeeId              String?
  name                    String
  email                   String?
  phone                   String?
  role                    String?
  department              String?
  departmentId            String?
  designation             String?
  dateOfBirth             DateTime?
  gender                  Gender?
  qualification           String?
  joinDate                DateTime                   @default(now())
  salary                  Decimal?                   @db.Decimal(10, 2)
  status                  StaffStatus                @default(ACTIVE)
  staffType               StaffType                  @default(TEACHING)
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  deletedAt               DateTime?
  sectionSubjectTeachings SectionSubjectTeacher[]    @relation("SectionSubjectTeacher")
  sectionClassTeacherOf   Section[]                  @relation("SectionClassTeacher")
  branch                  Branch                     @relation(fields: [branchId], references: [id], onDelete: Restrict)
  organization            Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user                    User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  departmentMaster        DepartmentMaster?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  staffAttendances        StaffAttendance[]
  documents               StaffDocument[]
  subjectAssignments      TeacherSubjectAssignment[]
  staffDesignations       StaffDesignation[]

  @@unique([branchId, employeeId])
  @@index([branchId])
  @@index([organizationId])
  @@index([departmentId])
  @@index([deletedAt])
  @@map("staff")
}

model StaffDocument {
  id        String   @id @default(cuid())
  staffId   String
  label     String
  fileName  String
  filePath  String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@map("staff_documents")
}

model TeacherSubjectAssignment {
  id        String  @id @default(cuid())
  staffId   String
  subjectId String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([staffId, subjectId])
  @@index([subjectId], map: "teacher_subject_assignments_subjectId_fkey")
  @@map("teacher_subject_assignments")
}

model SubjectMaster {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  code           String
  type           SubjectType  @default(THEORY)
  description    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subjects       Subject[]

  @@unique([organizationId, code])
  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("subject_masters")
}

model DepartmentMaster {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  code           String
  description    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staff          Staff[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@map("department_masters")
}

model DesignationMaster {
  id                String             @id @default(cuid())
  organizationId    String
  name              String
  code              String
  description       String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffDesignations StaffDesignation[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@map("designation_masters")
}

model StaffDesignation {
  id            String            @id @default(cuid())
  staffId       String
  designationId String
  createdAt     DateTime          @default(now())
  designation   DesignationMaster @relation(fields: [designationId], references: [id], onDelete: Cascade)
  staff         Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, designationId])
  @@index([staffId])
  @@index([designationId])
  @@map("staff_designations")
}

model SectionSubjectTeacher {
  id        String  @id @default(cuid())
  sectionId String
  subjectId String
  staffId   String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  staff     Staff   @relation("SectionSubjectTeacher", fields: [staffId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([sectionId, subjectId])
  @@index([sectionId])
  @@index([staffId])
  @@index([subjectId], map: "section_subject_teachers_subjectId_fkey")
  @@map("section_subject_teachers")
}

model StudentAttendance {
  id        String           @id @default(cuid())
  studentId String
  branchId  String
  sectionId String
  date      DateTime         @db.Date
  status    AttendanceStatus
  remarks   String?
  markedBy  String
  createdAt DateTime         @default(now())
  branch    Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  section   Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([branchId, date])
  @@index([sectionId, date])
  @@map("student_attendances")
}

model StaffAttendance {
  id        String           @id @default(cuid())
  staffId   String
  branchId  String
  date      DateTime         @db.Date
  status    AttendanceStatus
  checkIn   DateTime?
  checkOut  DateTime?
  remarks   String?
  createdAt DateTime         @default(now())
  branch    Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  staff     Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([branchId, date])
  @@map("staff_attendances")
}

model Timetable {
  id        String          @id @default(cuid())
  branchId  String
  name      String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  slots     TimetableSlot[]
  branch    Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("timetables")
}

model TimetableSlot {
  id          String    @id @default(cuid())
  timetableId String
  sectionId   String
  subjectId   String
  teacherId   String
  dayOfWeek   Int
  startTime   String
  endTime     String
  room        String?
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  timetable   Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  @@index([timetableId])
  @@index([sectionId])
  @@index([subjectId], map: "timetable_slots_subjectId_fkey")
  @@map("timetable_slots")
}

model FeeCategory {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  code           String
  description    String?
  isActive       Boolean        @default(true)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  feeStructures  FeeStructure[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@map("fee_categories")
}

model FeeStructure {
  id             String        @id @default(cuid())
  academicYearId String
  classId        String
  feeCategoryId  String
  amount         Decimal       @db.Decimal(10, 2)
  frequency      FeeFrequency  @default(MONTHLY)
  dueDate        Int?
  termType       TermType      @default(FULL_TERM)
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  feeCategory    FeeCategory   @relation(fields: [feeCategoryId], references: [id], onDelete: Cascade)
  invoiceItems   InvoiceItem[]

  @@unique([academicYearId, classId, feeCategoryId, termType])
  @@index([classId], map: "fee_structures_classId_fkey")
  @@index([feeCategoryId], map: "fee_structures_feeCategoryId_fkey")
  @@map("fee_structures")
}

model InstallmentMaster {
  id             String                   @id @default(cuid())
  organizationId String
  name           String
  code           String
  description    String?
  isActive       Boolean                  @default(true)
  deletedAt      DateTime?
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templates      FeeInstallmentTemplate[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@map("installment_masters")
}

model FeeInstallmentTemplate {
  id                  String             @id @default(cuid())
  classId             String
  academicYearId      String
  installmentMasterId String?
  name                String
  amount              Decimal            @db.Decimal(10, 2)
  dueDate             DateTime
  lateFeeActive       Boolean            @default(false)
  lateFeePerDay       Decimal            @default(0.00) @db.Decimal(10, 2)
  lateFeeGrace        Int                @default(0)
  lateFeeType         LateFeeType        @default(DAILY)
  lateFeeValue        Decimal            @default(0.00) @db.Decimal(10, 2)
  termType            TermType           @default(FULL_TERM)
  academicYear        AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class               Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  installmentMaster   InstallmentMaster? @relation(fields: [installmentMasterId], references: [id], onDelete: SetNull)

  @@index([classId])
  @@index([academicYearId], map: "fee_installment_templates_academicYearId_fkey")
  @@index([installmentMasterId])
  @@map("fee_installment_templates")
}

model Invoice {
  id                 String        @id @default(cuid())
  studentId          String
  number             String        @unique
  month              Int?
  year               Int
  totalAmount        Decimal       @db.Decimal(10, 2)
  paidAmount         Decimal       @default(0.00) @db.Decimal(10, 2)
  status             InvoiceStatus @default(PENDING)
  dueDate            DateTime
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  lateFeeAccumulated Decimal       @default(0.00) @db.Decimal(10, 2)
  lateFeeActive      Boolean       @default(false)
  lateFeeGrace       Int           @default(0)
  lateFeePerDay      Decimal       @default(0.00) @db.Decimal(10, 2)
  lateFeeWaived      Boolean       @default(false)
  proratedFromScheme String?
  lateFeeType        LateFeeType   @default(DAILY)
  lateFeeValue       Decimal       @default(0.00) @db.Decimal(10, 2)
  payments           FeePayment[]
  items              InvoiceItem[]
  student            Student       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  organizationId     String
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deletedAt          DateTime?

  @@index([studentId])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("invoices")
}

model InvoiceItem {
  id             String       @id @default(cuid())
  invoiceId      String
  feeStructureId String
  amount         Decimal      @db.Decimal(10, 2)
  description    String?
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([feeStructureId], map: "invoice_items_feeStructureId_fkey")
  @@index([invoiceId], map: "invoice_items_invoiceId_fkey")
  @@map("invoice_items")
}

model FeePayment {
  id            String        @id @default(cuid())
  invoiceId     String
  studentId     String
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  transactionId String?
  receiptNo     String?       @unique
  paidAt        DateTime      @default(now())
  remarks       String?
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deletedAt     DateTime?

  @@index([studentId])
  @@index([invoiceId])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("fee_payments")
}

model Exam {
  id             String        @id @default(cuid())
  academicYearId String
  name           String
  type           ExamType
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime      @default(now())
  subjects       ExamSubject[]
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@index([academicYearId])
  @@map("exams")
}

model ExamSubject {
  id        String   @id @default(cuid())
  examId    String
  subjectId String
  date      DateTime
  startTime String
  endTime   String
  maxMarks  Int
  passMarks Int
  room      String?
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  marks     Mark[]

  @@unique([examId, subjectId])
  @@index([subjectId], map: "exam_subjects_subjectId_fkey")
  @@map("exam_subjects")
}

model Mark {
  id            String      @id @default(cuid())
  examSubjectId String
  studentId     String
  marksObtained Decimal?    @db.Decimal(5, 2)
  grade         String?
  remarks       String?
  isAbsent      Boolean     @default(false)
  gradedBy      String
  createdAt     DateTime    @default(now())
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examSubjectId, studentId])
  @@index([studentId], map: "marks_studentId_fkey")
  @@map("marks")
}

model Vehicle {
  id          String           @id @default(cuid())
  branchId    String
  number      String
  type        String
  capacity    Int
  driverName  String?
  driverPhone String?
  isActive    Boolean          @default(true)
  routes      TransportRoute[]
  branch      Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, number])
  @@map("vehicles")
}

model TransportRoute {
  id        String             @id @default(cuid())
  branchId  String
  name      String
  vehicleId String?
  stops     RouteStop[]
  students  StudentTransport[]
  branch    Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  vehicle   Vehicle?           @relation(fields: [vehicleId], references: [id])

  @@index([branchId])
  @@index([vehicleId], map: "transport_routes_vehicleId_fkey")
  @@map("transport_routes")
}

model RouteStop {
  id         String         @id @default(cuid())
  routeId    String
  name       String
  pickupTime String?
  dropTime   String?
  sortOrder  Int
  route      TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId], map: "route_stops_routeId_fkey")
  @@map("route_stops")
}

model StudentTransport {
  id        String         @id @default(cuid())
  studentId String         @unique
  routeId   String
  stopName  String?
  route     TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([routeId], map: "student_transports_routeId_fkey")
  @@map("student_transports")
}

model Book {
  id              String      @id @default(cuid())
  branchId        String
  title           String
  author          String
  isbn            String?
  category        String?
  publisher       String?
  totalCopies     Int         @default(1)
  availableCopies Int         @default(1)
  shelfLocation   String?
  createdAt       DateTime    @default(now())
  issues          BookIssue[]
  branch          Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([isbn])
  @@map("books")
}

model BookIssue {
  id         String      @id @default(cuid())
  bookId     String
  studentId  String
  issuedAt   DateTime    @default(now())
  dueDate    DateTime
  returnedAt DateTime?
  fine       Decimal?    @db.Decimal(10, 2)
  status     IssueStatus @default(ISSUED)
  book       Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([studentId])
  @@map("book_issues")
}

model Hostel {
  id       String     @id @default(cuid())
  branchId String
  name     String
  type     HostelType
  warden   String?
  branch   Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  rooms    Room[]

  @@index([branchId])
  @@map("hostels")
}

model Room {
  id          String             @id @default(cuid())
  hostelId    String
  number      String
  floor       Int
  capacity    Int
  occupied    Int                @default(0)
  allocations HostelAllocation[]
  hostel      Hostel             @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@unique([hostelId, number])
  @@map("rooms")
}

model HostelAllocation {
  id        String    @id @default(cuid())
  studentId String    @unique
  roomId    String
  bedNumber String?
  startDate DateTime
  endDate   DateTime?
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([roomId], map: "hostel_allocations_roomId_fkey")
  @@map("hostel_allocations")
}

model Notice {
  id             String       @id @default(cuid())
  organizationId String
  branchId       String?
  title          String
  content        String       @db.Text
  targetRoles    String       @db.LongText
  isPublished    Boolean      @default(false)
  publishedAt    DateTime?
  createdBy      String
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?
  branch         Branch?      @relation(fields: [branchId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([branchId])
  @@map("notices")
}

model Event {
  id          String    @id @default(cuid())
  branchId    String
  title       String
  description String?   @db.Text
  startDate   DateTime
  endDate     DateTime?
  location    String?
  createdBy   String
  createdAt   DateTime  @default(now())
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("events")
}

model AdmissionInquiry {
  id             String                @id @default(cuid())
  organizationId String
  branchId       String
  academicYearId String
  studentName    String
  dateOfBirth    DateTime
  gender         Gender
  classAppliedId String
  parentName     String
  parentPhone    String
  parentEmail    String
  source         InquirySource         @default(WEBSITE)
  status         InquiryStatus         @default(INQUIRY)
  notes          String?               @db.Text
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  applications   AdmissionApplication?
  academicYear   AcademicYear          @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  branch         Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  classApplied   Class                 @relation(fields: [classAppliedId], references: [id], onDelete: Cascade)
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  followUps      InquiryFollowUp[]

  @@index([organizationId])
  @@index([branchId])
  @@index([academicYearId], map: "admission_inquiries_academicYearId_fkey")
  @@index([classAppliedId], map: "admission_inquiries_classAppliedId_fkey")
  @@map("admission_inquiries")
}

model InquiryFollowUp {
  id                String           @id @default(cuid())
  inquiryId         String
  counselorId       String
  followUpDate      DateTime         @default(now())
  conversationNotes String           @db.Text
  nextFollowUpDate  DateTime?
  statusReached     InquiryStatus
  inquiry           AdmissionInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@map("inquiry_follow_ups")
}

model AdmissionApplication {
  id                 String                @id @default(cuid())
  inquiryId          String?               @unique
  organizationId     String
  branchId           String
  academicYearId     String
  classId            String
  applicationNo      String                @unique
  firstName          String
  lastName           String
  dateOfBirth        DateTime
  gender             Gender
  bloodGroup         String?
  photo              String?
  address            String                @db.Text
  pincode            String
  previousSchool     String?
  emergencyContact   String
  fatherName         String?
  fatherPhone        String?
  fatherEmail        String?
  fatherOccupation   String?
  motherName         String?
  motherPhone        String?
  motherEmail        String?
  motherOccupation   String?
  status             ApplicationStatus     @default(SUBMITTED)
  applicationFeePaid Boolean               @default(false)
  verificationNotes  String?               @db.Text
  verifiedAt         DateTime?
  verifiedById       String?
  archiveReason      String?               @db.Text
  statusBeforeArchive String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  academicYear       AcademicYear          @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  branch             Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  class              Class                 @relation(fields: [classId], references: [id], onDelete: Cascade)
  inquiry            AdmissionInquiry?     @relation(fields: [inquiryId], references: [id])
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents          ApplicationDocument[]
  examResult         EntranceExamResult?

  @@index([organizationId])
  @@index([branchId])
  @@index([academicYearId], map: "admission_applications_academicYearId_fkey")
  @@index([classId], map: "admission_applications_classId_fkey")
  @@map("admission_applications")
}

model ApplicationDocument {
  id            String               @id @default(cuid())
  applicationId String
  documentType  String
  fileName      String
  filePath      String
  fileSize      Int
  status        DocumentStatus       @default(PENDING)
  remarks       String?
  application   AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_documents")
}

model EntranceExamResult {
  id            String               @id @default(cuid())
  applicationId String               @unique
  examDate      DateTime
  marksObtained Decimal?             @db.Decimal(5, 2)
  maxMarks      Decimal              @db.Decimal(5, 2)
  verdict       TestVerdict          @default(PENDING)
  notes         String?              @db.Text
  scheduledBy   String
  application   AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("entrance_exam_results")
}

enum ClassStatus {
  DRAFT
  ACTIVE
}

enum PlanType {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubjectType {
  THEORY
  PRACTICAL
  ELECTIVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  TRANSFERRED
  DROPPED
  SUSPENDED
}

enum StudentCategory {
  GENERAL
  RTE
  SCHOLARSHIP
  STAFF_CHILD
  OTHER
}

enum StaffStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
}

enum StaffType {
  TEACHING
  NON_TEACHING
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  EXCUSED
}

enum TermType {
  FULL_TERM
  HALF_TERM
  SHORT_TERM
}

enum LateFeeType {
  DAILY
  LUMP_SUM
  PERCENTAGE
}

enum FeeFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum PaymentMethod {
  CASH
  ONLINE
  CHEQUE
  BANK_TRANSFER
  UPI
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum ExamType {
  UNIT_TEST
  MID_TERM
  FINAL
  PRACTICAL
  ASSIGNMENT
}

enum IssueStatus {
  ISSUED
  RETURNED
  OVERDUE
  LOST
}

enum HostelType {
  BOYS
  GIRLS
}

enum InquirySource {
  WEBSITE
  WALK_IN
  SOCIAL_MEDIA
  REFERRAL
  NEWSPAPER
  OTHER
}

enum InquiryStatus {
  INQUIRY
  CONTACTED
  VISITED
  APPLIED
  CLOSED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  DOCUMENT_VERIFICATION
  TEST_SCHEDULED
  SHORTLISTED
  REJECTED
  ADMITTED
  WITHDRAWN
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TestVerdict {
  PENDING
  PASS
  FAIL
  BORDERLINE
}

model SystemSequence {
  id             String       @id @default(cuid())
  organizationId String
  type           String       // "ADMISSION", "INVOICE", "RECEIPT", "APPLICATION"
  year           Int
  currentValue   Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type, year])
  @@index([organizationId])
  @@map("system_sequences")
}

model IdempotencyKey {
  id             String    @id @default(cuid())
  key            String    @unique
  organizationId String
  status         String    // "PROCESSING" | "SUCCESS" | "FAILED"
  responseCode   Int?
  responseBody   String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([key])
  @@index([organizationId])
  @@map("idempotency_keys")
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(1)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("rate_limits")
}



